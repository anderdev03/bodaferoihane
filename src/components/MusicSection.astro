---

---

<section id="musica" class="bg-white px-4 py-24 sm:py-32">
    <div class="mx-auto max-w-3xl text-center" data-animate>
        <p class="font-serif text-sm uppercase tracking-[0.3em] text-muted">Música</p>
        <h2 class="mt-3 font-serif text-3xl font-normal sm:text-4xl">Nuestra Playlist</h2>
        <p class="mt-4 text-muted">Sugiere la canción que no puede faltar en la boda</p>
        <div class="mt-10 aspect-video w-full overflow-hidden rounded-lg bg-warm">
            <div class="flex h-full items-center justify-center">
                <p class="text-sm text-muted">Playlist de Spotify — próximamente</p>
            </div>
        </div>
        <div class="mt-8">
            <label for="cancion" class="mb-2 block text-left text-sm font-medium text-muted">
                Tu canción favorita:
            </label>
            <div class="flex gap-3">
                <input
                    type="text"
                    id="cancion"
                    placeholder="Artista — Canción"
                    class="flex-1 rounded-lg border border-accent-light/40 bg-cream px-4 py-3 text-sm outline-none transition focus:border-accent"
                />
                <button class="btn-accent">
                    Enviar
                </button>
            </div>
        </div>
    </div>
</section>
