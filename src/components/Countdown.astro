---
const { targetDate } = Astro.props
const [year, month, day] = targetDate.split('-')
---

<div id="countdown" class="mt-12" data-target={targetDate}>
    <div class="flex justify-center gap-8 sm:gap-12">
        <div class="text-center">
            <div id="countdown-days" class="font-serif text-4xl sm:text-5xl font-light text-accent">00</div>
            <p class="mt-1 text-xs uppercase tracking-widest text-muted">Días</p>
        </div>
        <div class="text-center">
            <div id="countdown-hours" class="font-serif text-4xl sm:text-5xl font-light text-accent">00</div>
            <p class="mt-1 text-xs uppercase tracking-widest text-muted">Horas</p>
        </div>
        <div class="text-center">
            <div id="countdown-minutes" class="font-serif text-4xl sm:text-5xl font-light text-accent">00</div>
            <p class="mt-1 text-xs uppercase tracking-widest text-muted">Min</p>
        </div>
        <div class="text-center">
            <div id="countdown-seconds" class="font-serif text-4xl sm:text-5xl font-light text-accent">00</div>
            <p class="mt-1 text-xs uppercase tracking-widest text-muted">Seg</p>
        </div>
    </div>
</div>

<script>
    (function () {
        const el = document.getElementById('countdown')
        if (!el) return
        const target = new Date(el.dataset.target + 'T12:00:00').getTime()

        function pad(n) {
            return String(n).padStart(2, '0')
        }

        function tick() {
            const now = Date.now()
            const diff = Math.max(0, target - now)
            const days = Math.floor(diff / 86400000)
            const hours = Math.floor((diff % 86400000) / 3600000)
            const minutes = Math.floor((diff % 3600000) / 60000)
            const seconds = Math.floor((diff % 60000) / 1000)

            const d = document.getElementById('countdown-days')
            const h = document.getElementById('countdown-hours')
            const m = document.getElementById('countdown-minutes')
            const s = document.getElementById('countdown-seconds')
            if (d) d.textContent = pad(days)
            if (h) h.textContent = pad(hours)
            if (m) m.textContent = pad(minutes)
            if (s) s.textContent = pad(seconds)
        }

        tick()
        setInterval(tick, 1000)
    })()
</script>
