---
const itinerary = [
    { time: '12:00', label: 'Ceremonia', desc: 'Lugar de la ceremonia' },
    { time: '13:30', label: 'Aperitivo', desc: 'Cóctel de bienvenida' },
    { time: '15:00', label: 'Banquete', desc: 'Comida y celebraciones' },
    { time: '22:00', label: 'Baile', desc: 'Fiesta y música' },
]
---

<section id="itinerario" class="bg-white px-4 py-24 sm:py-32">
    <div class="mx-auto max-w-5xl">
        <div class="mb-16 text-center">
            <p class="font-serif text-sm uppercase tracking-[0.3em] text-muted">Itinerario</p>
            <h2 class="mt-3 font-serif text-3xl font-normal sm:text-4xl">El día</h2>
        </div>
        <div class="relative">
            <div class="absolute inset-0 flex items-center justify-center opacity-[0.04]">
                <svg viewBox="0 0 500 600" class="h-full w-auto max-h-[500px]" xmlns="http://www.w3.org/2000/svg">
                    <path d="M250 80 L220 140 L180 160 L160 210 L170 260 L140 300 L150 350 L190 370 L210 400 L250 420 L290 400 L310 370 L350 350 L360 300 L330 260 L340 210 L320 160 L280 140 Z" fill="#2d2d2d" stroke="#2d2d2d" stroke-width="0.5"/>
                    <path d="M180 160 L160 210 L170 260 L140 300" fill="none" stroke="#2d2d2d" stroke-width="0.3"/>
                    <path d="M250 180 L250 300" fill="none" stroke="#2d2d2d" stroke-width="0.3" stroke-dasharray="4,4"/>
                    <circle cx="250" cy="180" r="3" fill="#2d2d2d"/>
                    <circle cx="250" cy="240" r="3" fill="#2d2d2d"/>
                    <circle cx="250" cy="300" r="3" fill="#2d2d2d"/>
                </svg>
            </div>
            <div class="relative z-10 mx-auto max-w-2xl">
                {itinerary.map((item, i) => (
                    <div class="flex items-start gap-6 pb-12 last:pb-0">
                        <div class="flex flex-col items-center">
                            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-accent/10">
                                <span class="font-serif text-sm font-semibold text-accent">{item.time}</span>
                            </div>
                            {i < itinerary.length - 1 && <div class="mt-2 h-full w-px bg-accent-light/40"></div>}
                        </div>
                        <div class="pt-3">
                            <p class="font-serif text-xl">{item.label}</p>
                            <p class="mt-1 text-sm text-muted">{item.desc}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </div>
</section>
