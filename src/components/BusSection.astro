---
const stops = [
    { time: '10:00', label: 'Pamplona', place: 'Avenida de la Paz, 1' },
    { time: '10:15', label: 'Noáin', place: 'Plaza del Ayuntamiento' },
]
---

<section id="bus" class="bg-warm px-4 py-24 sm:py-32">
    <div class="mx-auto max-w-3xl text-center">
        <p class="font-serif text-sm uppercase tracking-[0.3em] text-muted">Transporte</p>
        <h2 class="mt-3 font-serif text-3xl font-normal sm:text-4xl">Autobús</h2>
        <p class="mt-4 text-muted">Os recogeremos para ir todos juntos al lugar de la ceremonia</p>
        <div class="mt-12 space-y-6 text-left">
            {stops.map((stop) => (
                <div class="flex items-center gap-6 rounded-lg border border-accent-light/40 bg-white p-6">
                    <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-accent/10">
                        <span class="font-serif text-lg font-semibold text-accent">{stop.time}</span>
                    </div>
                    <div>
                        <p class="font-serif text-xl">{stop.label}</p>
                        <p class="mt-1 text-sm text-muted">{stop.place}</p>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>
