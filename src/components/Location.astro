---
const { name, address } = Astro.props
---

<section id="ubicacion" class="bg-white px-4 py-24 sm:py-32">
    <div class="mx-auto max-w-4xl">
        <div class="mb-16 text-center">
            <p class="font-serif text-sm uppercase tracking-[0.3em] text-muted">El lugar</p>
            <h2 class="mt-3 font-serif text-3xl font-normal sm:text-4xl">{name}</h2>
        </div>
        <div class="aspect-[16/9] w-full overflow-hidden rounded-lg bg-warm">
            <div class="flex h-full items-center justify-center">
                <div class="text-center text-muted">
                    <svg class="mx-auto h-12 w-12 text-accent-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    <p class="mt-4 text-sm">Foto del lugar</p>
                </div>
            </div>
        </div>
        <div class="mt-8 text-center">
            <p class="text-lg text-muted">{address}</p>
        </div>
    </div>
</section>
